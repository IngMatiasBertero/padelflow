# ========================================
# PadelFlow - Variables de Entorno
# ========================================

# Gemini API Key (para insights con IA)
# Obtener en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# JWT Secret (generar con: openssl rand -base64 32)
# IMPORTANTE: Usar un valor único y seguro en producción
JWT_SECRET=cambiar_esto_en_produccion

# ========================================
# URLs (solo si usas Cloudflare o dominio personalizado)
# ========================================

# URL del frontend (para CORS)
# Local: http://localhost:7000
# Cloudflare: https://padelflow.tudominio.com
FRONTEND_URL=https://padelflow.bertium.net

# URL del backend API
# Local: http://localhost:7001
# Cloudflare: https://api.padelflow.tudominio.com
API_URL=https://api.padelflow.bertium.net
